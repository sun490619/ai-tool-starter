/** index.wxss **/
.page {
  min-height: 100vh;
}

.hero {
  text-align: center;
  padding: 32px 0;
}

.badge {
  display: inline-block;
  margin-bottom: 16px;
}

.hero-title {
  display: block;
  font-size: 26px;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.3;
  margin-bottom: 12px;
}

page[theme="dark"] .hero-title {
  color: #f1f5f9;
}

.highlight {
  color: #0ea5e9;
}

.hero-desc {
  display: block;
  font-size: 15px;
  color: #64748b;
  line-height: 1.7;
  margin-bottom: 24px;
  padding: 0 16px;
}

page[theme="dark"] .hero-desc {
  color: #94a3b8;
}

.hero-actions {
  display: flex;
  gap: 12px;
  padding: 0 16px;
  margin-bottom: 32px;
}

.hero-actions .btn {
  flex: 1;
}

.btn-icon {
  margin-right: 6px;
}

.features {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 0 16px;
}

.feature {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  background: #f8fafc;
  border-radius: 12px;
  text-align: left;
}

page[theme="dark"] .feature {
  background: #1e293b;
}

.feature-icon {
  font-size: 22px;
  flex-shrink: 0;
}

.feature-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 4px;
}

page[theme="dark"] .feature-title {
  color: #f1f5f9;
}

.feature-desc {
  display: block;
  font-size: 13px;
  color: #64748b;
}

page[theme="dark"] .feature-desc {
  color: #94a3b8;
}

/* 使用指南 */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.guide-item {
  display: flex;
  gap: 12px;
}

.guide-num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #0ea5e9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 13px;
  flex-shrink: 0;
}

.guide-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 2px;
}

page[theme="dark"] .guide-title {
  color: #f1f5f9;
}

.guide-desc {
  display: block;
  font-size: 13px;
  color: #64748b;
}

page[theme="dark"] .guide-desc {
  color: #94a3b8;
}

/* FAQ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.faq-item {
  background: #f8fafc;
  border-radius: 10px;
  padding: 16px;
}

page[theme="dark"] .faq-item {
  background: #1e293b;
}

.faq-q {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #0ea5e9;
  margin-bottom: 8px;
}

.faq-a {
  display: block;
  font-size: 13px;
  color: #64748b;
  line-height: 1.6;
}

page[theme="dark"] .faq-a {
  color: #94a3b8;
}

/* Footer */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 24px 16px;
}

.footer-link {
  color: #94a3b8;
}