          <text class="feature-desc">每年本金、投入、收益、余额一目了然</text>
        </view>
        <view class="feature">
          <text class="feature-icon">📈</text>
          <text class="feature-title">可视化图表</text>
          <text class="feature-desc">直观展示复利效应，看清财富增长曲线</text>
        </view>
      </view>
    </view>

    <!-- 广告位 -->
    <view class="ad-placeholder">广告位预留 (In-article)</view>

    <!-- 使用指南 -->
    <view class="card">
      <text class="section-title">📖 使用指南</text>
      <view class="guide-list">
        <view class="guide-item">
          <text class="guide-num">1</text>
          <view class="guide-content">
            <text class="guide-title">填写基础参数</text>
            <text class="guide-desc">输入初始本金、月定投金额、预期年化收益率、投资年限</text>
          </view>
        </view>
        <view class="guide-item">
          <text class="guide-num">2</text>
          <view class="guide-content">
            <text class="guide-title">选择复利频率</text>
            <text class="guide-desc">支持年复利、半年复利、季度复利、月复利、日复利</text>
          </view>
        </view>
        <view class="guide-item">
          <text class="guide-num">3</text>
          <view class="guide-content">
            <text class="guide-title">查看结果分析</text>
            <text class="guide-desc">获得期末总额、总投入、总收益、复利贡献率等核心指标</text>
          </view>
        </view>
        <view class="guide-item">
          <text class="guide-num">4</text>
          <view class="guide-content">
            <text class="guide-title">导出或分享</text>
            <text class="guide-desc">支持年度明细表导出、结果分享给好友</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 常见问题 -->
    <view class="card">
      <text class="section-title">❓ 常见问题</text>
      <view class="faq-list">
        <view class="faq-item">
          <text class="faq-q">复利和单利有什么区别？</text>
          <text class="faq-a">单利只计算本金利息，复利将利息加入本金继续产生利息，时间越长差距越大。</text>
        </view>
        <view class="faq-item">
          <text class="faq-q">定投怎么计算复利？</text>
          <text class="faq-a">每期定投金额按剩余期数复利计算，本工具支持月度定投自动展开计算每年明细。</text>
        </view>
        <view class="faq-item">
          <text class="faq-q">数据会上传服务器吗？</text>
          <text class="faq-a">不会。所有计算纯前端完成，无任何网络请求，您的财务数据完全私密。</text>
        </view>
        <view class="faq-item">
          <text class="faq-q">结果准确吗？</text>
          <text class="faq-a">采用标准复利公式计算，精确到分。仅供参考，实际投资请以机构结算为准。</text>
        </view>
      </view>
    </view>
